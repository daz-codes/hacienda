<% page_title "Field Notes" %>

<section>
  <p class="eyebrow">A Hacienda example</p>
  <h1>Field Notes</h1>
  <p>A small blog built with explicit domains, Ruby objects, ERB, and Helium.</p>

  <% posts.each do |post| %>
    <article class="post-card">
      <h2><%= link post.title, path("/posts/:id", id: post.id) %></h2>
      <p><%= post.body[0, 180] %></p>
    </article>
  <% end %>

  <% if posts.empty? %>
    <p>No published posts yet.</p>
  <% end %>
</section>
