<%= error_messages errors %>

<%= form_start action, method:, context:, class: "stacked-form" %>
  <label>
    Pizza name
    <input name="name" value="<%= pizza.name %>" required autofocus>
  </label>

  <label>
    Description
    <textarea name="description" rows="5" required><%= pizza.description %></textarea>
  </label>

  <label>
    Price
    <span class="money-input"><span>&pound;</span><input name="price" type="number" min="0.01" step="0.01" value="<%= pizza.price %>" required></span>
  </label>

  <div class="check-row">
    <label><input type="checkbox" name="vegetarian" value="1" <%= "checked" if pizza.vegetarian %>> Vegetarian</label>
    <label><input type="checkbox" name="available" value="1" <%= "checked" if pizza.available %>> Available to order</label>
  </div>

  <div class="page-actions">
    <button type="submit" class="button button-primary"><%= submit_label %></button>
    <%= link "Cancel", pizza.id ? "/pizzas/#{pizza.id}" : "/pizzas" %>
  </div>
<%= form_end %>
