{
  "name": "lunula-framework-tests",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test:client": "vitest run",
    "test:morpheus": "vitest run packages/morpheus/test",
    "test:browser": "playwright test",
    "test:package": "npm test --workspace @lunula/morpheus && node script/check_morpheus_vendoring.mjs && npm pack --dry-run --workspace @lunula/morpheus"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "jsdom": "^27.0.1",
    "vitest": "^3.2.4"
  }
}
