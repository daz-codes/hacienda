</article>

===== db/migrations/TIMESTAMP_create_posts.rb =====
Sequel.migration do
  change do
    create_table(:posts) do
      primary_key :id
      String :title, null: false
      String :body, text: true, null: false
      DateTime :created_at, null: false
      DateTime :updated_at, null: false
    end
  end
end

===== test/domains/posts/actions_test.rb =====
# frozen_string_literal: true

require_relative "../../test_helper"

class PostsActionsTest < ApplicationTest
  def setup
    super
    database[:posts].delete
  end

  def test_create_redirects_to_the_persisted_record
    post "/posts", {
      _csrf: csrf_token,
      title: "Created through HTTP",
      body: "Domain action contract"
    }

    assert_equal 303, last_response.status
    record = database[:posts].first
    assert_equal "/posts/#{record[:id]}", last_response["location"]

    get last_response["location"]
    assert_equal 200, last_response.status
    assert_includes last_response.body, "Created through HTTP"
  end
end

===== test/domains/posts/post_test.rb =====
# frozen_string_literal: true

require_relative "../../test_helper"

class PostsPostTest < Minitest::Test
  def test_title_and_body_are_required
    record = Posts::Post.new

    refute record.valid?
    assert_includes record.errors.full_messages, "Title is required"
    assert_includes record.errors.full_messages, "Body is required"
  end

  def test_complete_record_is_valid
    record = Posts::Post.new(title: "First", body: "Useful body")

    assert record.valid?
  end
end

===== test/domains/posts/repository_test.rb =====
# frozen_string_literal: true

require_relative "../../test_helper"

class PostsRepositoryTest < Minitest::Test
  def setup
    APP.database[:posts].delete
  end

  def test_saved_records_can_be_found
    record = Posts::Post.new(title: "Saved", body: "Repository contract")

    Posts::Repository.save(record)
    found = Posts::Repository.find(record.id)

    assert_equal record.id, found.id
    assert_equal "Saved", found.title
    assert_equal record.id, Posts::Repository.find_by!(title: "Saved").id
    assert_nil Posts::Repository.find_by(title: "Missing")
    assert_raises(Lunula::NotFound) { Posts::Repository.find(0) }
  end
end
